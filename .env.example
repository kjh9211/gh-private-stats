# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Local     → Callback URL: http://localhost:3000/auth/callback
# Vercel    → Callback URL: https://<your-project>.vercel.app/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Option A — single connection string (Vercel/Neon/Supabase)
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Option B — individual vars (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=github_stats
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave unset to use memory-only cache.
# Upstash (recommended for Vercel): rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP=60
RATE_LIMIT_PER_TOKEN=20
