# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Local:
#   Homepage URL:   http://localhost:3000
#   Callback URL:   http://localhost:3000/auth/callback
# Vercel:
#   Homepage URL:   https://<your-project>.vercel.app
#   Callback URL:   https://<your-project>.vercel.app/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=github_stats
DB_USER=postgres
DB_PASSWORD=your_db_password

# Vercel / Neon / Supabase — use DATABASE_URL instead of individual vars:
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local
REDIS_URL=redis://localhost:6379
# Upstash (recommended for Vercel):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP=60
RATE_LIMIT_PER_TOKEN=20
